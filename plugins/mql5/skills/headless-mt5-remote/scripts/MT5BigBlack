#!/bin/bash
# macOS Spotlight app launcher for MT5 BigBlack VNC
# Lives inside /Applications/MT5 BigBlack.app/Contents/MacOS/
# SSH tunnel + clipboard sync + TigerVNC — one click

DIR="$(dirname "$0")"

# Kill any existing tunnel/clipboard
lsof -ti:5900 | xargs kill 2>/dev/null
pkill -f clipboard-sync.sh 2>/dev/null
sleep 0.5

# SSH tunnel (background)
ssh -f -N -L 5900:localhost:5900 tca@bigblack

# Clipboard sync: macOS → bigblack via SSH (background)
"$DIR/clipboard-sync.sh" &
CLIP_PID=$!

sleep 1

# TigerVNC (single-dash flags, NOT double-dash)
/Applications/TigerVNC.app/Contents/MacOS/vncviewer \
  -SecurityTypes None \
  localhost:5900

# Cleanup when TigerVNC closes
kill $CLIP_PID 2>/dev/null
pkill -f clipboard-sync.sh 2>/dev/null
